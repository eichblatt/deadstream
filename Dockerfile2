FROM python:3.11-slim

# Setup working directory
WORKDIR /app

# Install dependencies
COPY requirements.txt .
COPY setup.py .
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install -e .

# Copy your application code
COPY deadstream/ ./deadstream/

# Set environment variables for Google Cloud
ENV GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json

# Command to run your script
ENTRYPOINT ["python", "-m", "deadstream.update_cloud_meta"]
CMD ["--collections", "existing", "--save_cloud", "1"]